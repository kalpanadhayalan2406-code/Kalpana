<!DOCTYPE html>
<html>
<head>
<title>Event Registration Page</title>

<style>

body{
font-family: Arial, sans-serif;
background-color:#f2f6ff;
margin:0;
padding:0;
}

h1{
text-align:center;
color:#1e3c72;
}

.container{
width:60%;
margin:auto;
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 0 10px gray;
}

label{
font-weight:bold;
}

input,select{
width:100%;
padding:8px;
margin:8px 0;
border-radius:5px;
border:1px solid #ccc;
}

button{
background:#1e3c72;
color:white;
padding:10px;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#2a5298;
}

table{
width:80%;
margin:20px auto;
border-collapse:collapse;
}

th,td{
border:1px solid black;
padding:10px;
text-align:center;
}

th{
background:#1e3c72;
color:white;
}

</style>
</head>

<body>

<h1>Event Registration</h1>

<div class="container">

<form id="form">

<label>Name</label>
<input type="text" id="name" required>

<label>Email</label>
<input type="email" id="email" required>

<label>Phone Number</label>
<input type="text" id="phone" required>

<label>Event</label>
<select id="event">
<option value="">Select Event</option>
<option>Web Development</option>
<option>UI/UX Workshop</option>
<option>AI Seminar</option>
</select>

<label>Mode</label>
<select id="mode">
<option value="">Select Mode</option>
<option>Online</option>
<option>Offline</option>
</select>

<br><br>

<button type="submit">Register</button>

</form>

</div>

<h2 style="text-align:center;">Registered Participants</h2>

<table id="table">

<tr>
<th>Name</th>
<th>Email</th>
<th>Phone</th>
<th>Event</th>
<th>Mode</th>
</tr>

<tr>
<td>Ananya</td>
<td>ananya@gmail.com</td>
<td>9876543210</td>
<td>Web Development</td>
<td>Online</td>
</tr>

<tr>
<td>Rahul</td>
<td>rahul@gmail.com</td>
<td>9123456780</td>
<td>UI/UX Workshop</td>
<td>Offline</td>
</tr>

</table>

<script>

document.getElementById("form").addEventListener("submit", function(e){

e.preventDefault();

let name=document.getElementById("name").value;
let email=document.getElementById("email").value;
let phone=document.getElementById("phone").value;
let event=document.getElementById("event").value;
let mode=document.getElementById("mode").value;

let table=document.getElementById("table");

let row=table.insertRow(-1);

row.insertCell(0).innerHTML=name;
row.insertCell(1).innerHTML=email;
row.insertCell(2).innerHTML=phone;
row.insertCell(3).innerHTML=event;
row.insertCell(4).innerHTML=mode;

document.getElementById("form").reset();

alert("Registration Successful");

});

</script>

</body>
</html>
